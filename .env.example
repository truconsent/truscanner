# Copy this file to `.env` and fill in only the provider settings you use.
# truScanner loads values from `.env` and from exported shell environment variables.

# OpenAI
OPENAI_KEY=

# AWS Bedrock
TRUSCANNER_ACCESS_KEY_ID=
TRUSCANNER_SECRET_ACCESS_KEY=
TRUSCANNER_REGION=us-east-1
TRUSCANNER_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Ollama
# No API key is required. Make sure Ollama is running and a model is installed locally.

# Optional truScanner AI tuning
TRUSCANNER_AI_MODE=balanced
TRUSCANNER_AI_MAX_PROMPT_CHARS=
TRUSCANNER_AI_MAX_MODEL_OUTPUT_TOKENS=
TRUSCANNER_AI_MAX_RELEVANT_LINES=
TRUSCANNER_AI_NUM_CTX=
